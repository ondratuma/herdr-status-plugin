#!/usr/bin/env bash
set -euo pipefail

# herdr-status — per-pane activity status for herdr agent panes. THREE parts work together:
#
#   1. A herdr PLUGIN (`~/.config/herdr/plugins/claude-status/herdr-plugin.toml`, linked with
#      `herdr plugin link`) captures herdr's lifecycle events natively. Its `[[events]]` hooks
#      run `herdr-status __run event` on `pane.agent_detected` / `pane.agent_status_changed`,
#      passing the event JSON (pane_id + agent_status). That is the event-capture half.
#
#   2. This SYSTEM COMMAND (`herdr-status <verb>`) lets an agent self-report intent:
#        working ⚡|looping 🔁|waiting ⏳|input ✋|done ✅ [detail]   ·   clear (→ auto)   ·   off (stop)
#      Self-reports set what the pane's STOPPED states (idle/blocked/done) display, so herdr
#      reveals the icon the instant the pane goes idle. `waiting/input/done` release when the
#      agent works again; `working/looping` (working-state badges) persist until clear/done.
#      Also: `link` registers the plugin into the current session's server; `agents` lists every
#      agent pane across ALL herdr sessions.
#
#   3. A DAEMON (`herdr-status __run daemon`) advances the counting TIMER between events and
#      registers/prunes panes via `herdr pane list`. herdr already reports each pane's agent_status,
#      so an idle pane simply shows the idle icon (💤) — no output-matching needed. ONE daemon per
#      herdr server (keyed by socket): each session gets its own daemon + state dir under
#      ~/.config/herdr/claude-status/<session>/ so concurrent sessions don't collide.
#
# Display: each state_label is `<icon> <timer>` (herdr swaps the icon per detected state — ⚡ work,
# 🔁 loop, 💤 idle, ✅/⏳/✋ on a self-report, 💀 once stale); the self-reported detail rides in
# custom_status, so the sidebar reads e.g. `⚡ 6m fixing parser`. Each push has a short TTL so a
# dead daemon self-cleans. Safe anywhere: a no-op outside herdr (HERDR_ENV != 1), best-effort.

STATE_ROOT="${HOME}/.config/herdr/claude-status"

# Per-herdr-server namespace: each herdr session has its own socket, panes, state dir, and daemon,
# so concurrent sessions don't collide (pane ids like "w3:p4" repeat across servers). The key is
# the session name herdr uses: `default`, or the <name> under ~/.config/herdr/sessions/<name>/.
server_key() {
	local sock="${HERDR_SOCKET_PATH:-$HOME/.config/herdr/herdr.sock}"
	case "$sock" in
		"$HOME/.config/herdr/herdr.sock") printf 'default' ;;
		"$HOME/.config/herdr/sessions/"*/herdr.sock)
			local k="${sock#"$HOME"/.config/herdr/sessions/}"; printf '%s' "${k%/herdr.sock}" ;;
		*) printf '%s' "${sock//[^A-Za-z0-9]/_}" ;;
	esac
}
STATE_DIR="${STATE_ROOT}/$(server_key)"
DAEMON_PID="${STATE_DIR}/daemon.pid"

# Repo root (parent of bin/), resolving symlinks — used to find lib/ and plugin/.
resolve_repo() {
	local src="${BASH_SOURCE[0]}" dir
	while [ -h "$src" ]; do
		dir="$(cd -P "$(dirname "$src")" && pwd)"
		src="$(readlink "$src")"
		case "$src" in /*) ;; *) src="$dir/$src" ;; esac
	done
	dir="$(cd -P "$(dirname "$src")" && pwd)"
	(cd -P "$dir/.." && pwd)
}

usage() {
	echo "Usage: $0 <working|looping|waiting|input|done|clear|off|link|agents> [detail]" >&2
	exit 1
}

sanitize()   { printf '%s' "${HERDR_PANE_ID//[^A-Za-z0-9]/_}"; }
state_file() { printf '%s/%s.state' "$STATE_DIR" "$(sanitize)"; }

daemon_alive() {
	local pid
	[ -f "$DAEMON_PID" ] || return 1
	pid="$(cat "$DAEMON_PID" 2>/dev/null || true)"
	[ -n "$pid" ] || return 1
	kill -0 "$pid" 2>/dev/null
}

ensure_daemon() {
	daemon_alive && return 0
	mkdir -p "$STATE_DIR"
	( nohup "$0" __run daemon </dev/null >/dev/null 2>&1 & echo $! > "$DAEMON_PID" )
	return 0
}

stop_daemon() {
	local pid
	[ -f "$DAEMON_PID" ] || return 0
	pid="$(cat "$DAEMON_PID" 2>/dev/null || true)"
	rm -f "$DAEMON_PID"
	[ -n "$pid" ] && kill "$pid" 2>/dev/null || true
	return 0
}

# state file: intent (auto|working|looping|waiting|input|done), detail, since-epoch, manual-epoch (0=auto)
write_state() {
	local sf
	sf="$(state_file)"
	mkdir -p "$STATE_DIR"
	printf '%s\n%s\n%s\n%s\n' "$1" "$2" "$3" "$4" > "$sf.tmp" && mv "$sf.tmp" "$sf"
}

# ---- dispatch ----
[ $# -ge 1 ] || usage
verb="$1"
shift || true

# internal entrypoint: __run <event | push PANE | clearpane PANE | daemon> —
# the implementation lives in ../lib/herdr-status.py (run via the resolved path below).
if [ "$verb" = "__run" ]; then
	[ -n "${HERDR_ENV:-}" ] || exit 0
	command -v python3 >/dev/null 2>&1 || exit 0
	# absolute path, so the daemon re-spawn (Popen) works no matter how we were invoked
	# (herdr runs the event hook as the manifest's relative `bin/herdr-status`).
	export HERDR_STATUS_BIN="$(resolve_repo)/bin/herdr-status"
	impl="$(resolve_repo)/lib/herdr-status.py"   # .py lives in the repo's lib/, off PATH
	[ -f "$impl" ] || exit 0
	exec python3 "$impl" "$@"
fi

# cross-session overview: list every agent pane in every herdr session (works outside herdr too)
if [ "$verb" = "agents" ] || [ "$verb" = "ls" ]; then
	command -v python3 >/dev/null 2>&1 || { echo "python3 required" >&2; exit 1; }
	impl="$(resolve_repo)/lib/herdr-status.py"
	[ -f "$impl" ] || { echo "missing $impl" >&2; exit 1; }
	exec python3 "$impl" agents
fi

# link the plugin into THIS session's herdr server (named sessions start with no plugins) + start
# its daemon. Run it from a pane in the session you want tracked.
if [ "$verb" = "link" ]; then
	command -v herdr >/dev/null 2>&1 || { echo "herdr not found" >&2; exit 1; }
	plugin_dir="$(resolve_repo)"
	herdr plugin unlink ot.claude-status >/dev/null 2>&1 || true
	if herdr plugin link "$plugin_dir" >/dev/null 2>&1; then
		echo "herdr: plugin linked into session '$(server_key)' — its agents are now tracked"
		ensure_daemon
	else
		echo "herdr: plugin link failed (is this session's server running?)" >&2
		exit 1
	fi
	exit 0
fi

detail="${1:-}"

[ -n "${HERDR_ENV:-}" ] || exit 0

case "$verb" in
	working|looping|waiting|input|done)
		now="$(date +%s)"
		write_state "$verb" "$detail" "$now" "$now"
		"$0" __run push "$HERDR_PANE_ID"
		ensure_daemon
		echo "herdr: $verb${detail:+ ($detail)} — live"
		;;
	clear)
		write_state auto "" "$(date +%s)" 0
		"$0" __run push "$HERDR_PANE_ID"
		ensure_daemon
		echo "herdr: back to auto tracking"
		;;
	off)
		stop_daemon
		"$0" __run clearpane "$HERDR_PANE_ID"
		rm -f "$STATE_DIR"/*.state "$STATE_DIR"/*.last 2>/dev/null || true
		echo "herdr: tracker stopped for session '$(server_key)' (panes fade within ~3m)"
		;;
	__ensure)
		ensure_daemon
		;;
	*) usage ;;
esac
