#!/usr/bin/env bash
set -euo pipefail

# herdr-status-rename — rename the CURRENT herdr pane. Sets both:
#   • the pane label  (pane/tab title)            via `herdr pane rename`
#   • the sidebar display name (the agent label)  via `herdr pane report-metadata --display-agent`
# (the sidebar reads display_agent, not label, so both are needed to show the name everywhere).
#
# Usage:
#   herdr-status-rename <name...>    rename to <name> (all args joined; spaces allowed)
#   herdr-status-rename --clear      clear the custom name (revert to the detected default)
#
# A no-op outside a herdr session (HERDR_ENV != 1) so it is always safe to call.

[ -n "${HERDR_ENV:-}" ] || { echo "herdr-status-rename: not inside a herdr pane (HERDR_ENV != 1)" >&2; exit 0; }
[ $# -ge 1 ] || { echo "Usage: herdr-status-rename <name> | --clear" >&2; exit 1; }

pane="${HERDR_PANE_ID:-}"
if [ -z "$pane" ]; then
	pane="$(herdr pane current | python3 -c 'import sys,json; print(json.load(sys.stdin)["result"]["pane"]["pane_id"])')"
fi
[ -n "$pane" ] || { echo "herdr-status-rename: could not resolve the current pane" >&2; exit 1; }

# the name is stored keyed by the pane's AGENT SESSION id (setname/clearname in the
# python impl), so it survives herdr server restarts and follows a resumed session into
# a new pane; the daemon re-applies it as display_agent + the $name token. Panes without
# a session id (no agent integration) fall back to a pane-scoped display_agent.
if [ "$1" = "--clear" ]; then
	herdr pane rename "$pane" --clear >/dev/null
	herdr pane report-metadata "$pane" --source rename --clear-display-agent >/dev/null 2>&1 || true
	"$(dirname "$0")/herdr-status" __run clearname "$pane" 2>/dev/null || true
	echo "herdr: cleared name on $pane"
else
	name="$*"
	herdr pane rename "$pane" "$name" >/dev/null
	# drop any legacy pane-scoped name from the old rename source so it can't shadow
	herdr pane report-metadata "$pane" --source rename --clear-display-agent >/dev/null 2>&1 || true
	"$(dirname "$0")/herdr-status" __run setname "$pane" "$name" 2>/dev/null || true
	echo "herdr: renamed $pane → $name"
fi
