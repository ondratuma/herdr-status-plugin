#!/usr/bin/env bash
set -euo pipefail

# herdr-pane-rename — rename the CURRENT herdr pane. Sets both:
#   • the pane label  (pane/tab title)            via `herdr pane rename`
#   • the sidebar display name (the agent label)  via `herdr pane report-metadata --display-agent`
# (the sidebar reads display_agent, not label, so both are needed to show the name everywhere).
#
# Usage:
#   herdr-pane-rename <name...>      rename to <name> (all args joined; spaces allowed)
#   herdr-pane-rename --clear        clear the custom name (revert to the detected default)
#
# A no-op outside a herdr session (HERDR_ENV != 1) so it is always safe to call.

[ -n "${HERDR_ENV:-}" ] || { echo "herdr-pane-rename: not inside a herdr pane (HERDR_ENV != 1)" >&2; exit 0; }
[ $# -ge 1 ] || { echo "Usage: herdr-pane-rename <name> | --clear" >&2; exit 1; }

# the current pane — prefer the herdr-injected id, else ask herdr
pane="${HERDR_PANE_ID:-}"
if [ -z "$pane" ]; then
	pane="$(herdr pane current | python3 -c 'import sys,json; print(json.load(sys.stdin)["result"]["pane"]["pane_id"])')"
fi
[ -n "$pane" ] || { echo "herdr-pane-rename: could not resolve the current pane" >&2; exit 1; }

if [ "$1" = "--clear" ]; then
	herdr pane rename "$pane" --clear >/dev/null
	herdr pane report-metadata "$pane" --source rename --clear-display-agent >/dev/null
	echo "herdr: cleared name on $pane"
else
	name="$*"
	herdr pane rename "$pane" "$name" >/dev/null
	herdr pane report-metadata "$pane" --source rename --display-agent "$name" >/dev/null
	echo "herdr: renamed $pane → $name"
fi
